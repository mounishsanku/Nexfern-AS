PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/nexfern

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED (production): minimum 32 random characters, not "change_me"
JWT_SECRET=change_me_to_a_32_char_random_string

# ── Encryption ────────────────────────────────────────────────────────────────
# REQUIRED (production): exactly 32 characters for AES-256
BACKUP_ENCRYPTION_KEY=change_me_exactly_32_chars_here!

# ── Security ──────────────────────────────────────────────────────────────────
# When true, audit log insert failures abort the request (strict mode)
AUDIT_STRICT=false

# When false, debits that would make Cash/Bank negative are blocked
ALLOW_NEGATIVE_CASH=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (required in production)
# CORS_ORIGINS=https://app.nexfern.com,https://admin.nexfern.com

# ── Upload ────────────────────────────────────────────────────────────────────
JSON_BODY_LIMIT=32mb

# ── Environment ───────────────────────────────────────────────────────────────
# NODE_ENV=production   # Enables stricter env validation

# ── Feature Flags (override per deployment) ───────────────────────────────────
# These are stored in CompanySettings in DB; env vars are for infrastructure only.

# ── Integration Credentials (encrypted at rest, never commit raw values) ──────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
